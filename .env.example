# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Server-only: VTT sample uploads in /admin/vtt-samples (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Comma-separated emails allowed to open /admin/vtt-samples
SCRYER_ADMIN_EMAILS=you@example.com

# Optional: local Ollama for "Suggest tags" on /admin/vtt-samples (image assets only).
# 1) ollama pull deepseek-ocr
# 2) Set the model name so the server is allowed to call Ollama:
OLLAMA_TAG_MODEL=deepseek-ocr
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# Vision requests resize images server-side; raise context if the model still errors (see model max in Ollama):
# OLLAMA_NUM_CTX=16384
# OLLAMA_NUM_PREDICT=512
# OLLAMA_TAG_TIMEOUT_MS=180000
